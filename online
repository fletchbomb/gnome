<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gnome Invasion Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Added PeerJS for Multiplayer -->
  <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>

  <style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap');
  :root {
    /* Official palette foundation */
    --ink-950:#120e0a;
    --wood-950:#1a120d;
    --wood-900:#2b1e16;
    --wood-850:#332419;
    --wood-800:#3a2a1f;
    --wood-750:#4b3425;
    --wood-700:#5a3f2b;
    --wood-650:#6a4a32;
    --wood-600:#7a563a;
    --wood-550:#8a6342;
    --wood-500:#9c7643;
    --brass-500:#d6a652;
    --brass-400:#e7c17c;
    --brass-350:#f0d49b;
    --gold-300:#f2c06b;
    --parchment-100:#f4e6c8;
    --parchment-200:#e9d7b4;
    --parchment-300:#d9c29a;
    --parchment-400:#cdbb94;
    --moss-500:#8ea86a;

    /* Semantic state colors */
    --danger-700:#7f2424;
    --danger-600:#8d2a2a;
    --danger-500:#c24a3f;
    --danger-400:#ff6b6b;
    --success-600:#285a3f;
    --success-500:#31734f;
    --magic-700:#5b21b6;
    --magic-600:#7c3aed;
    --magic-500:#8d63c7;
    --magic-400:#c084fc;

    /* Legacy aliases mapped to official palette */
    --bg:var(--wood-950);
    --panel:var(--wood-800);
    --card:var(--wood-700);
    --accent:var(--brass-500);
    --gold:var(--gold-300);
    --green:var(--moss-500);
    --text:var(--parchment-100);
    --muted:var(--parchment-400);
    --radius:10px;
    --ui-dark:var(--wood-900);
    --ui-panel:var(--wood-800);
    --ui-panel-2:var(--wood-700);
    --ui-panel-3:var(--wood-650);
    --ui-accent:var(--brass-500);
    --ui-accent-glow:var(--gold-300);
    --ui-text:var(--parchment-100);
    --ui-text-dim:var(--parchment-400);
    --ui-shadow:var(--ink-950);
    --ui-border:#7a5737;
    --ui-border-soft:rgba(214,166,82,.24);

    /* Semantic component tokens */
    --color-bg-app:var(--wood-950);
    --color-bg-overlay:rgba(0,0,0,.72);
    --color-surface-panel:var(--wood-800);
    --color-surface-panel-strong:var(--wood-900);
    --color-surface-board:var(--wood-700);
    --color-surface-elevated:var(--wood-750);
    --color-surface-inset:var(--wood-900);
    --color-surface-card:linear-gradient(180deg, rgba(90,63,43,.97), rgba(43,30,22,.99));
    --color-surface-card-strong:linear-gradient(180deg, rgba(106,74,50,.97), rgba(58,42,31,.99));
    --color-surface-button:linear-gradient(180deg, var(--wood-650), var(--wood-750));
    --color-surface-button-hover:linear-gradient(180deg, var(--wood-600), var(--wood-700));
    --color-surface-button-disabled:linear-gradient(180deg, rgba(88,62,42,.78), rgba(50,35,25,.82));
    --color-surface-tooltip:linear-gradient(180deg, rgba(79,55,35,.98), rgba(43,30,22,.98));
    --color-surface-card-mat:radial-gradient(ellipse at 50% 60%, rgba(109,74,43,.96) 0%, rgba(61,40,25,.98) 58%, rgba(33,22,15,1) 100%);
    --color-surface-slot:linear-gradient(180deg, rgba(67,47,33,.96), rgba(43,30,22,.98));
    --color-surface-slot-empty:linear-gradient(180deg, rgba(52,36,25,.92), rgba(30,20,14,.98));
    --color-surface-start-card:linear-gradient(180deg, rgba(92,64,42,.96), rgba(43,30,22,.99));
    --color-surface-start-button:linear-gradient(180deg, var(--brass-500), #b7863a);
    --color-surface-start-button-hover:linear-gradient(180deg, var(--gold-300), var(--brass-500));
    --color-surface-debug:linear-gradient(180deg, rgba(106,74,50,.96), rgba(58,42,31,.98));
    --color-surface-debug-muted:linear-gradient(180deg, rgba(88,62,42,.94), rgba(43,30,22,.98));
    --color-surface-weaver-trade:linear-gradient(180deg, #8b6a3d, #6a4a2a);
    --color-surface-weaver-trade-hover:linear-gradient(180deg, #9c7643, #78532e);

    --color-border-default:#7a5737;
    --color-border-soft:rgba(214,166,82,.18);
    --color-border-strong:rgba(214,166,82,.38);
    --color-border-card:rgba(214,166,82,.12);
    --color-border-disabled:rgba(146,108,72,.34);

    --color-text-primary:var(--parchment-100);
    --color-text-muted:var(--parchment-400);
    --color-text-soft:var(--parchment-300);
    --color-text-strong:var(--gold-300);

    --color-accent-primary:var(--brass-500);
    --color-accent-gold:var(--gold-300);
    --color-accent-glow:var(--gold-300);
    --color-accent-positive:var(--moss-500);

    --radius-sm:7px;
    --radius-md:var(--radius);
    --radius-lg:14px;
    --board-cell-size:162px;
    --board-gap:4px;
    --shadow-card-pop:0 10px 30px rgba(0,0,0,.7);
    --shadow-panel-deep:0 8px 40px #000c;
    --font-display:'Fredoka One',cursive;
    --font-body:'Nunito',sans-serif;
    --board-bg-tile-url:
url("https://raw.githubusercontent.com/fletchbomb/gnome/main/files/backgroundtile.png");
    --board-surface-step:calc(var(--board-cell-size) + var(--board-gap));
    --board-surface-seam-dark:rgba(4,6,10,.28);
    --board-surface-seam-mid:rgba(10,14,22,.16);
    --board-surface-seam-highlight:rgba(255,240,212,.015);
    --board-surface-vignette:rgba(0,0,0,.88);
    --board-surface-glow:rgba(255,196,112,.03);
    --board-surface-tile-darken:rgba(0,0,0,.36);
    --board-room-gap-fill:rgba(4,6,10,.82);
    --board-room-shadow-heavy:
  0 10px 22px rgba(0,0,0,.45),
  0 5px 12px rgba(0,0,0,.35),
  0 0 0 1px rgba(0,0,0,.50),
  0 0 0 2px rgba(0,0,0,.30),
  0 0 0 3px rgba(0,0,0,.14);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:var(--font-body);background:var(--color-bg-app);color:var(--color-text-primary);min-height:100vh;overflow-x:hidden;}
  h1,h2,h3{font-family:var(--font-display);}

  /* Semantic UI shell hooks for future theme swaps */
  .ui-shell-app{}
  .ui-shell-header{}
  .ui-shell-main{}
  .ui-shell-board-area{}
  .ui-shell-sidebar{}
  .ui-shell-log{}
  .ui-shell-overlay{}
  .ui-shell-panel{}
  .ui-shell-popup{}
  .ui-shell-card{}
  .ui-shell-token{}
  #app{position:relative;height:100vh;overflow:hidden;background:var(--color-bg-app);filter:sepia(.08) saturate(1.05);}
  #header{position:absolute;top:12px;left:12px;right:332px;z-index:40;padding:0;display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:8px;background:transparent;border:none;pointer-events:none;}
  #header > *{pointer-events:auto;}
  #header h1{font-size:1.4rem;color:var(--gold);padding:7px 12px;border-radius:14px;background:linear-gradient(180deg, rgba(84,56,34,.96), rgba(43,30,22,.98));border:1px solid rgba(214,166,82,.35);box-shadow:0 8px 20px rgba(0,0,0,.32);}
  #main{position:relative;height:100%;overflow:hidden;}
  #board-area{position:absolute;inset:0;overflow:auto;padding:24px 24px 116px 24px;display:flex;align-items:safe center;justify-content:safe center;background:radial-gradient(circle at center, rgba(64,43,28,.98) 0%, rgba(28,18,12,.995) 54%, rgba(12,8,6,1) 100%);}
  #board-area.pan-ready{cursor:grab;}
  #board-area.is-panning{cursor:grabbing;user-select:none;}
  #board-area.is-panning,
  #board-area.is-panning *{cursor:grabbing !important;}
  #sidebar{position:fixed;left:50%;transform:translateX(-50%);top:auto;right:auto;bottom:12px;width:auto;padding:0;overflow:visible;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;gap:10px;background:transparent;border:none;z-index:45;pointer-events:none;}
  #sidebar > *{pointer-events:auto;}
  #log-area{position:relative;left:auto;right:auto;bottom:auto;top:auto;width:100%;max-height:none;background:transparent;border:none;border-radius:0;padding:8px 0 0;z-index:auto;box-shadow:none;backdrop-filter:none;overflow:hidden;}
  #top-left-shell{position:fixed;top:12px;left:auto;right:12px;width:min(316px,calc(100vw - 24px));z-index:45;padding:0;background:transparent;border:none;box-shadow:none;display:flex;flex-direction:column;gap:10px;}
  #top-left-shell #header{position:relative;inset:auto;background:transparent;border:none;box-shadow:none;padding:0;}
  #top-left-shell #header-summary{display:flex;flex-direction:column;gap:8px;width:100%;}
  #header-brand{display:none !important;}
  #header-meta-row{display:flex;justify-content:flex-end;align-items:center;gap:6px;pointer-events:auto;}
  .header-hidden-phase{display:none !important;}
  .header-mini-chip{display:inline-flex;align-items:center;justify-content:center;gap:4px;min-height:24px;padding:4px 8px;border-radius:999px;background:linear-gradient(180deg, rgba(79,55,35,.92), rgba(43,30,22,.94));border:1px solid rgba(214,166,82,.24);box-shadow:0 10px 18px rgba(0,0,0,.24), inset 0 0 0 1px rgba(255,245,224,.04);font:800 .68rem/1 var(--font-body);color:var(--ui-text);backdrop-filter:blur(6px);transition:transform .18s ease,box-shadow .18s ease,background .18s ease,opacity .18s ease;transform:translateY(0);} 
  .header-mini-chip:hover{transform:translateY(-1px);background:linear-gradient(180deg, rgba(103,73,46,.94), rgba(58,40,27,.96));box-shadow:0 14px 22px rgba(0,0,0,.28), inset 0 0 0 1px rgba(255,245,224,.05);}
  .header-mini-chip:active{transform:translateY(1px) scale(.985);}
  #header-focus-row{display:grid;grid-template-columns:minmax(0,1fr) auto;align-items:end;gap:10px;pointer-events:auto;}
  #trouble-bar-wrap{position:relative;background:transparent;border-radius:0;padding:0;min-width:0;width:100%;display:flex;flex-direction:column;gap:6px;transition:transform .18s ease,filter .22s ease;transform:translateY(0);}
  #trouble-bar-wrap:hover{transform:translateY(-1px);filter:brightness(1.04);}
  #trouble-bar-wrap:active{transform:translateY(1px) scale(.995);}
  #trouble-readout{display:flex;align-items:flex-end;gap:5px;padding-left:2px;color:var(--ui-text);text-shadow:0 2px 6px rgba(0,0,0,.38);}
  #trouble-icon{font-size:1.05rem;line-height:1;padding-bottom:3px;filter:drop-shadow(0 0 6px rgba(255,116,116,.32));}
  #trouble-val{font-size:1.58rem;line-height:.9;font-weight:900;letter-spacing:.01em;}
  #trouble-max{font-size:.76rem;line-height:1;opacity:.7;padding-bottom:2px;}
  #trouble-bar-bg{position:relative;background:linear-gradient(180deg, rgba(58,40,27,.92), rgba(30,20,14,.94));border-radius:999px;height:24px;overflow:hidden;border:1px solid rgba(214,166,82,.18);box-shadow:0 12px 24px rgba(0,0,0,.26), inset 0 0 0 1px rgba(255,245,224,.04);}
  #trouble-bar-fill{position:absolute;left:0;top:0;bottom:0;border-radius:999px;transition:width .5s cubic-bezier(.2,.9,.2,1),background .35s ease,box-shadow .28s ease,filter .2s ease;will-change:width,background,box-shadow,transform;transform-origin:left center;background:linear-gradient(90deg, #d6a652, #f2c06b);z-index:1;box-shadow:0 0 18px rgba(242,192,107,.26);}
  #trouble-bar-bg::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(to right, transparent 0 calc(5% - 1px), rgba(214,166,82,.12) calc(5% - 1px) 5%);pointer-events:none;z-index:2;}
  #trouble-bar-markers{position:absolute;inset:0;pointer-events:none;z-index:3;}
  .trouble-marker{position:absolute;top:50%;transform:translate(-50%,-50%);font-size:11px;line-height:1;opacity:.44;filter:grayscale(.2);text-shadow:0 1px 2px rgba(0,0,0,.9);transition:opacity .22s,transform .22s,filter .22s,text-shadow .22s;}
  .trouble-marker.active{opacity:.96;filter:none;transform:translate(-50%,-50%) scale(1.14);} 
  .trouble-marker.next-danger{opacity:.9;filter:none;transform:translate(-50%,-50%) scale(1.1);text-shadow:0 0 8px rgba(255,232,150,.6),0 1px 2px rgba(0,0,0,.9);animation:headerNextMarkerPulse 1.5s ease-in-out infinite;}
  .trouble-marker.threshold-flash{animation:headerThresholdFlash .8s ease;}
  #socks-chip{position:relative;display:inline-flex;align-items:center;gap:8px;align-self:flex-end;padding:8px 12px 9px;border-radius:999px;background:linear-gradient(180deg, rgba(111,76,52,.94), rgba(58,40,27,.96));border:1px solid rgba(214,166,82,.28);box-shadow:0 14px 24px rgba(0,0,0,.26), 0 0 18px rgba(242,192,107,.10), inset 0 0 0 1px rgba(255,245,224,.04);backdrop-filter:blur(6px);transition:transform .18s ease,box-shadow .18s ease,filter .22s ease;transform:translateY(0);overflow:visible;}
  #socks-chip:hover{transform:translateY(-1px);filter:brightness(1.04);}
  #socks-chip:active{transform:translateY(1px) scale(.99);}
  #socks-chip .socks-icon{font-size:1.28rem;line-height:1;filter:drop-shadow(0 0 7px rgba(242,192,107,.24));}
  #socks-readout{display:flex;align-items:flex-end;gap:2px;color:var(--ui-text);}
  #Socks-count{font-size:1.56rem;line-height:.9;font-weight:900;letter-spacing:.01em;color:var(--gold);}
  #socks-goal-wrap{font-size:.76rem;line-height:1;opacity:.72;padding-bottom:2px;}
  .header-pressable{cursor:default;user-select:none;-webkit-user-select:none;touch-action:manipulation;}
  .trouble-bump #trouble-bar-fill{animation:headerTroubleBump .45s ease;}
  .trouble-settle #trouble-bar-fill{animation:headerTroubleSettle .4s ease;}
  #trouble-bar-wrap.high-alert #trouble-bar-bg{box-shadow:0 12px 24px rgba(0,0,0,.26), 0 0 14px rgba(244,67,54,.18), inset 0 0 0 1px rgba(255,255,255,.04);}
  #trouble-bar-wrap.high-alert #trouble-icon{animation:headerHighDangerPulse 2.1s ease-in-out infinite;}
  #socks-chip.sock-pop{animation:headerSockPop .55s cubic-bezier(.2,.9,.2,1);}
  #socks-chip.goal-glow{animation:headerGoalGlow 1.15s ease;}
  .sock-burst{position:absolute;right:18px;bottom:10px;font-size:16px;pointer-events:none;text-shadow:0 2px 6px rgba(0,0,0,.35);animation:headerSockBurst .9s ease-out forwards;}
  @keyframes headerTroubleBump{0%{transform:scaleX(1)}35%{transform:scaleX(1.035)}100%{transform:scaleX(1)}}
  @keyframes headerTroubleSettle{0%{transform:scaleX(1)}40%{transform:scaleX(.985)}100%{transform:scaleX(1)}}
  @keyframes headerThresholdFlash{0%{opacity:1;transform:translate(-50%,-50%) scale(1.06)}25%{opacity:1;transform:translate(-50%,-50%) scale(1.42)}100%{opacity:.96;transform:translate(-50%,-50%) scale(1.14)}}
  @keyframes headerNextMarkerPulse{0%,100%{opacity:.72;transform:translate(-50%,-50%) scale(1.05)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.16)}}
  @keyframes headerHighDangerPulse{0%,100%{filter:drop-shadow(0 0 6px rgba(255,116,116,.32))}50%{filter:drop-shadow(0 0 12px rgba(255,116,116,.58))}}
  @keyframes headerSockPop{0%{transform:translateY(0) scale(1)}30%{transform:translateY(-2px) scale(1.08)}55%{transform:translateY(0) scale(.98)}100%{transform:translateY(0) scale(1)}}
  @keyframes headerGoalGlow{0%{box-shadow:0 14px 24px rgba(0,0,0,.26), 0 0 18px rgba(242,192,107,.10), inset 0 0 0 1px rgba(255,245,224,.04)}35%{box-shadow:0 16px 26px rgba(0,0,0,.28), 0 0 28px rgba(242,192,107,.34), inset 0 0 0 1px rgba(255,245,224,.08)}100%{box-shadow:0 14px 24px rgba(0,0,0,.26), 0 0 18px rgba(242,192,107,.10), inset 0 0 0 1px rgba(255,245,224,.04)}}
  @keyframes headerSockBurst{0%{opacity:0;transform:translateY(6px) scale(.75)}20%{opacity:1}100%{opacity:0;transform:translateY(-24px) translateX(5px) scale(1.12)}}
  @media (max-width: 560px){
    #top-left-shell{right:8px;top:8px;width:min(280px,calc(100vw - 16px));gap:8px;}
    #header-meta-row{gap:5px;}
    .header-mini-chip{padding:4px 7px;font-size:.64rem;}
    #header-focus-row{gap:8px;}
    #trouble-bar-bg{height:22px;}
    #socks-chip{padding:7px 10px 8px;}
    #Socks-count{font-size:1.44rem;}
  }
  #top-left-shell #log-area.collapsed{width:100%;}
  #top-left-shell #log{max-height:min(24vh,200px);}
  .tracker-row{flex-wrap:nowrap;align-items:center;display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
  .tracker{background:linear-gradient(180deg, rgba(92,64,42,.98), rgba(51,35,25,.98));border:1px solid rgba(214,166,82,.18);border-radius:var(--radius);padding:4px 6px;font-weight:700;font-size:0.66rem;text-align:center;min-width:0;display:flex;align-items:center;justify-content:center;gap:2px;}
  .tracker.good{background:linear-gradient(180deg, #5b4a2f, #3b2d1d);color:#f0d49b;border:1px solid rgba(214,166,82,.28);}
  .tracker-compact{padding:3px 4px !important; min-width:0;}

  .audio-toggle-btn{
    margin-left:0;
    width:24px;
    height:24px;
    border-radius:999px;
    border:1px solid rgba(214,166,82,.28);
    background:linear-gradient(180deg, rgba(111,76,52,.94), rgba(58,40,27,.96));
    color:var(--ui-text);
    display:inline-flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    box-shadow:0 0 8px rgba(242,192,107,.20), inset 0 0 8px rgba(255,245,224,.05);
    transition:transform .15s ease, box-shadow .15s ease, background .15s ease, border-color .15s ease, opacity .15s ease;
    flex:0 0 auto;
  }
  .audio-toggle-btn:hover{
    transform:translateY(-1px);
    box-shadow:0 0 14px rgba(242,192,107,.32), inset 0 0 10px rgba(255,245,224,.08);
  }
  .audio-toggle-btn .audio-icon{
    font-size:11px;
    line-height:1;
    filter:drop-shadow(0 0 4px rgba(242,192,107,.45));
  }
  .audio-toggle-btn.muted{
    background:transparent;
    box-shadow:inset 0 0 0 1px rgba(214,166,82,.16);
    border-color:rgba(214,166,82,.22);
    opacity:.8;
  }


  #header .tracker-row{justify-content:flex-start;pointer-events:auto;}
  #sidebar::-webkit-scrollbar,#board-area::-webkit-scrollbar{width:10px;height:10px;}
  #sidebar::-webkit-scrollbar-thumb,#board-area::-webkit-scrollbar-thumb{background:#6f4c34;border-radius:999px;}
  #sidebar > :not(#actions-shell):not(#gnomes-shell):not(#patrol-tray){display:none !important;}
  #actions-shell,#gnomes-shell{display:flex;flex-direction:column;gap:6px;}
  #patrol-tray{z-index:25;display:flex;flex-direction:column;align-items:flex-start;gap:10px;}
  .floating-panel{background:linear-gradient(180deg, rgba(72,50,35,.96), rgba(43,30,22,.98));border:1px solid rgba(214,166,82,.28);border-radius:16px;padding:10px 12px;box-shadow:0 12px 36px rgba(0,0,0,.35);} 
  .gnome-stack{display:flex;flex-direction:column;gap:8px;}
  #bottom-dock{position:fixed;left:12px;right:auto;top:12px;bottom:auto;transform:none;display:flex;flex-direction:column;justify-content:flex-start;align-items:flex-start;gap:10px;z-index:45;pointer-events:none;max-width:min(360px,calc(100vw - 24px));}
  #bottom-dock > *{pointer-events:auto;}
  #gnome-panels{position:relative;left:auto;right:auto;bottom:auto;display:flex;flex-direction:column;justify-content:flex-start;align-items:flex-start;gap:10px;z-index:auto;pointer-events:none;flex-wrap:nowrap;overflow:visible;width:100%;}
  #gnome-panels > *{pointer-events:auto;}
  #actions .section-title, #gnomes-shell > .section-title{margin-bottom:0;}
  #actions{display:flex;flex-direction:row;align-items:flex-start;justify-content:flex-start;gap:0;width:100%;flex-wrap:nowrap;}
  #actions-shell .floating-title-row{display:none;}
  #actions-shell #current-gnome-info{width:100%;text-align:center;}
  #primary-action-grid{margin:0;}
  #actions-shell .action-btn-grid, #actions-shell .action-btn.end-turn{margin-left:0;margin-right:0;}

  #room-detail,.legend,#hamper-display,#patrol-display,#current-gnome-info{display:none !important;}
  .floating-title-row{display:flex;align-items:center;justify-content:space-between;gap:8px;}
  .floating-title-row .section-title{margin-bottom:0;}
  .inline-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 8px;border-radius:999px;background:linear-gradient(180deg, #6f4c34, #3a2a1f);border:1px solid rgba(214,166,82,.28);color:var(--text);font-size:.66rem;font-weight:800;white-space:nowrap;}
  .inline-badge.turn{border-color:rgba(242,192,107,.68);color:var(--gold);}
  .inline-badge.actions{border-color:rgba(196,171,108,.55);color:#f0d49b;} 
  .gnome-meta{display:flex;flex-wrap:wrap;gap:5px;margin:0 0 6px;}
  #log-area.collapsed #log{display:none;}
  #log-area:not(.collapsed) #log-latest{display:none;}
