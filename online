  .cell.room.shroom-target:hover{border-color:#c084fc;}
  .cell.room.kick-dest{border-color:#f59e0b;box-shadow:var(--board-room-shadow-heavy), 0 0 10px #f59e0b88, 0 0 26px 12px rgba(20,14,6,.42);}
  .cell.room.vent-dest{border-color:#4dd0e1;box-shadow:var(--board-room-shadow-heavy), 0 0 10px #4dd0e188, 0 0 26px 12px rgba(6,16,18,.42);}
  .cell.room.patrol-new{animation:patrolPulse 1s ease-in-out infinite;}
  .cell.room.dynamite-active{z-index:40;isolation:isolate;overflow:visible;}
  .cell.room.dynamite-active:hover{z-index:60;}

  @keyframes patrolPulse{0%,100%{border-color:#ff4444;box-shadow:0 0 6px #ff444488;}50%{border-color:#ff0000;box-shadow:0 0 18px #ff0000cc;}}
  .game-card.patrol-spawn  { --card-border:#ff4444; --card-header-bg:#2a0606; --card-pip:#ff4444; }
  #game-tooltip{position:fixed;z-index:10000;background:var(--color-surface-tooltip);border:1px solid var(--color-border-strong);border-radius:8px;padding:6px 11px;font-size:.75rem;color:var(--color-text-primary);white-space:pre-wrap;max-width:220px;pointer-events:none;display:none;box-shadow:0 10px 24px rgba(0,0,0,.42), inset 0 0 0 1px rgba(255,245,224,.04);line-height:1.4;font-family:'Nunito',sans-serif;}
  /* Patrol turn announcement banner */
  #patrol-banner{display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:500;background:var(--color-surface-tooltip);border:3px solid var(--danger-500);border-radius:16px;padding:18px 36px;text-align:center;font-family:'Fredoka One';font-size:1.6rem;color:var(--ui-text);box-shadow:0 8px 40px #000c;pointer-events:none;}
  #patrol-banner.show{display:block;animation:bannerPop .3s ease-out;}
  /* When a card is showing, blur elements behind the card overlay */
  body.card-showing #patrol-banner,
  body.card-showing #patrol-tray,
  body.card-showing #board,
  body.card-showing #sidebar,
  body.card-showing #log-area,
  body.card-showing #header {
    opacity: 0.55;
    transition: opacity 0.12s ease;
  }
  @keyframes bannerPop{from{transform:translate(-50%,-50%) scale(.7);opacity:0}to{transform:translate(-50%,-50%) scale(1);opacity:1}}

  /* ── PANIC INTERRUPT OVERLAY ─────────────────────────────────────────── */
  #panic-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 450;
    pointer-events: none;
    border: 4px solid transparent;
    animation: panicBorderPulse 1s ease-in-out infinite;
  }
  #panic-overlay.show { display: block; }

  #explosion-flash{
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:700;
    display:none;
    background:
      radial-gradient(circle at center, rgba(255,245,180,.92) 0%, rgba(255,180,70,.75) 18%, rgba(255,90,0,.45) 38%, rgba(255,40,0,.18) 58%, rgba(0,0,0,0) 74%);
    mix-blend-mode:screen;
  }
  #explosion-flash.show{
    display:block;
    animation: explosionFlashPulse .6s ease-out forwards;
  }
  @keyframes explosionFlashPulse{
    0%{opacity:0; transform:scale(.96);}
    12%{opacity:1; transform:scale(1);}
    45%{opacity:.55; transform:scale(1.02);}
    100%{opacity:0; transform:scale(1.05);}
  }

  @keyframes panicBorderPulse {
    0%,100% { border-color: rgba(239,68,68,0); box-shadow: inset 0 0 0px rgba(239,68,68,0); }
    50%      { border-color: rgba(239,68,68,.9); box-shadow: inset 0 0 60px rgba(239,68,68,.18); }
  }
  #panic-banner {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 460;
    background: linear-gradient(90deg, rgba(127,0,0,.85), rgba(220,38,38,.92), rgba(127,0,0,.85));
    color: #fff;
    font-family: 'Fredoka One';
    font-size: 1.1rem;
    text-align: center;
    padding: 6px 16px;
    letter-spacing: .06em;
    pointer-events: none;
    animation: panicBannerPulse 1s ease-in-out infinite;
  }
  #panic-banner.show { display: block; }
  @keyframes panicBannerPulse {
    0%,100% { opacity: .8; }
    50%      { opacity: 1; }
  }
  /* Dim everything on the board except move targets and current gnome room during panic */
  body.panic-mode #board .cell.room:not(.move-target):not(.current-gnome) {
    opacity: 0.35;
    filter: saturate(0.2);
  }
  body.panic-mode #board .cell.room.move-target {
    border-color: #ff4444 !important;
    box-shadow: 0 0 12px #ff444488 !important;
    animation: panicTargetPulse .8s ease-in-out infinite;
  }
  @keyframes panicTargetPulse {
    0%,100% { box-shadow: 0 0 8px #ff444466; }
    50%      { box-shadow: 0 0 20px #ff4444bb; }
  }
  body.panic-mode #sidebar { opacity: 0.25; pointer-events: none; }
  body.panic-mode #log-area { opacity: 0.25; }
  /* Animated patrol meeple */
  .patrol-meeple-anim{position:fixed;z-index:600;font-size:1.6rem;pointer-events:none;transition:left 3s ease-in-out, top 3s ease-in-out;}

  /* Card popup overlay */
  /* ── PLAYING CARD OVERLAY ── */
  /* ═══════════════════════════════════════
     CARD OVERLAY & MAT
  ═══════════════════════════════════════ */
  #card-overlay{
    display:none; position:fixed; inset:0; z-index:800;
    align-items:center; justify-content:center;
    background:rgba(0,0,0,.72);
    contain:layout style paint;
  }
  #card-overlay.show{display:flex;align-items:center;justify-content:center;}

  /* Felt mat underneath the card */
  #card-mat {
    position:relative;
    display:flex; align-items:center; justify-content:center;
    width:300px; height:388px;
    background: var(--color-surface-card-mat);
    border-radius:22px;
    box-shadow:
      0 0 0 2px rgba(214,166,82,.42),
      0 0 0 5px rgba(61,40,25,.95),
      0 8px 40px #000e,
      inset 0 0 40px rgba(0,0,0,.5);
  }

  /* ═══════════════════════════════════════
     THE CARD ITSELF — playing card proportions
     2.5" × 3.5" scaled → 220 × 308px
  ═══════════════════════════════════════ */
  .game-card {
    width: 220px;
    height: 308px;
    border-radius: 14px;
    position: relative;
    cursor: pointer;
    overflow: hidden;
    transform-origin: center center;
    will-change: transform, opacity;
    contain: layout style paint;
    /* rich multi-layer shadow */
    box-shadow:
      0 0 0 2px var(--card-border, #f5a623),
      0 4px 0 2px color-mix(in srgb, var(--card-border,#f5a623) 40%, #000),
      0 10px 30px rgba(0,0,0,.7),
      0 2px 6px rgba(0,0,0,.5);
    /* Entrance: slide in from left with slight arc */
    animation: cardDeal .55s cubic-bezier(.22,.68,0,1.15) forwards;
    user-select: none;
  }

  @keyframes cardDeal {
    0%   {
      transform: translateX(-140vw) rotate(-22deg) scale(.8);
      opacity: 0;
      box-shadow: 0 0 0 2px var(--card-border,#f5a623), 0 2px 0 2px #000, 0 30px 60px rgba(0,0,0,.9);
    }
    55%  {
      transform: translateX(12px) rotate(2.5deg) scale(1.04);
      opacity: 1;
    }
    72%  { transform: translateX(-4px) rotate(-.8deg) scale(.98); }
    86%  { transform: translateX(2px) rotate(.3deg) scale(1.005); }
    100% { transform: translateX(0) rotate(0deg) scale(1); opacity: 1; }
  }

  .game-card.dismissing {
    animation: cardDismiss .4s cubic-bezier(.55,0,1,.7) forwards !important;
    pointer-events: none;
  }
  @keyframes cardDismiss {
    0%   { transform: translateX(0) rotate(0deg) scale(1); opacity: 1; }
    15%  { transform: translateX(-6px) rotate(-1.5deg) scale(1.01); }
    100% { transform: translateX(140vw) rotate(16deg) scale(.85); opacity: 0; }
  }

  /* Colour themes — each card type gets its own palette */
  .game-card.trouble       { --card-border:#ff5555; --card-bg-top:#2a0808; --card-bg-bot:#1a0404; --card-pip:#ff6666; --card-shine:rgba(255,80,80,.12); }
  .game-card.event-good    { --card-border:#4ade80; --card-bg-top:#0a2a14; --card-bg-bot:#061a0c; --card-pip:#4ade80; --card-shine:rgba(74,222,128,.1); }
  .game-card.event-trouble { --card-border:#f59e0b; --card-bg-top:#2a1a00; --card-bg-bot:#1a0f00; --card-pip:#fbbf24; --card-shine:rgba(251,191,36,.1); }
  .game-card.event-patrol  { --card-border:#a855f7; --card-bg-top:#1a0a2a; --card-bg-bot:#0f0518; --card-pip:#c084fc; --card-shine:rgba(168,85,247,.1); }
  .game-card.patrol-spawn  { --card-border:#ff4444; --card-bg-top:#2a0606; --card-bg-bot:#1a0303; --card-pip:#ff6666; --card-shine:rgba(255,60,60,.12); }
  #game-card-back{display:none;pointer-events:none;position:absolute;left:-24px;top:34px;transform:rotate(-5deg) scale(.985);opacity:.98;z-index:1;}
  #game-card-back.show{display:block;animation:cardBaseSettle .22s ease-out forwards;}
  #game-card-inner.stacked-front{position:absolute;left:142px;top:18px;z-index:2;}
  @keyframes cardBaseSettle{
    from{transform:translate3d(-12px,8px,0) rotate(-7deg) scale(.97);opacity:0;}
    to{transform:translate3d(0,0,0) rotate(-5deg) scale(.985);opacity:.98;}
  }
  @keyframes cardBumpBase{
    0%{transform:translate3d(166px,-16px,0) rotate(0deg) scale(1);opacity:1;}
    58%{transform:translate3d(-10px,2px,0) rotate(-7.5deg) scale(.985);opacity:.99;}
    100%{transform:translate3d(0,0,0) rotate(-5deg) scale(.985);opacity:.98;}
  }
  @keyframes cardStackDeal{
    from{transform:translate3d(240px,4px,0) rotate(10deg) scale(.97);opacity:0;}
    to{transform:translate3d(0,0,0) rotate(4deg) scale(1);opacity:1;}
  }

  /* ── Card face structure ── */
  .card-face {
    width:100%; height:100%;
    display:flex; flex-direction:column;
    border-radius:14px; overflow:hidden;
    background: linear-gradient(160deg, var(--card-bg-top, #1a0a28) 0%, var(--card-bg-bot, #0a0515) 100%);
  }

  /* Diagonal shine overlay */
  .card-face::before {
    content:'';
    position:absolute; inset:0;
    background: linear-gradient(135deg,
      var(--card-shine, rgba(255,255,255,.06)) 0%,
      transparent 50%,
      rgba(0,0,0,.15) 100%);
    border-radius:14px;
    pointer-events:none; z-index:2;
  }

  /* ── Top corner pip area ── */
  .card-top-pip {
    padding: 8px 10px 4px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-shrink: 0;
    position:relative; z-index:3;
  }
  .pip-left, .pip-right {
    display:flex; flex-direction:column; align-items:center; line-height:1;
    gap:1px;
  }
  .pip-right { transform: rotate(180deg); }
  .pip-emoji { font-size:.9rem; }
  .pip-label {
    font-size:.42rem; font-weight:900; letter-spacing:.08em;
    color: var(--card-pip, #f5a623);
    font-family:'Fredoka One'; text-transform:uppercase;
    white-space:nowrap;
  }

  /* ── Center divider line ── */
  .card-divider {
    height:1px;
    background: linear-gradient(90deg, transparent, var(--card-pip,#f5a623), transparent);
    opacity:.3; margin: 0 16px; flex-shrink:0;
  }

  /* ── Main body ── */
  .card-body {
    flex:1;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    padding: 6px 14px 4px;
    gap: 6px;
    position:relative; z-index:3;
  }
  .card-type-band {
    font-size:.44rem; letter-spacing:.2em; text-transform:uppercase;
    color: var(--card-pip, #f5a623); font-family:'Fredoka One';
    opacity:.8;
  }
  .card-emoji-big {
    font-size: 3.2rem; line-height:1;
    filter: drop-shadow(0 3px 8px rgba(0,0,0,.6));
    animation: cardEmojiPop .5s .3s cubic-bezier(.22,.68,0,1.4) both;
  }
  @keyframes cardEmojiPop {
    0%   { transform: scale(0) rotate(-15deg); opacity:0; }
    70%  { transform: scale(1.15) rotate(4deg); }
    100% { transform: scale(1) rotate(0deg); opacity:1; }
  }
  .card-name-big {
    font-family:'Fredoka One'; font-size:1.1rem; color:var(--ui-text);
    text-align:center; line-height:1.2;
    text-shadow: 0 1px 6px rgba(0,0,0,.7);
  }
  .card-desc-body {
    font-size:.68rem; color:#bcd; text-align:center;
    line-height:1.55; font-family:'Nunito',sans-serif;
    opacity:.9;
  }

  /* ── Footer ── */
  .card-footer {
    padding: 8px 10px 10px;
    display:flex; align-items:center; justify-content:center;
    flex-shrink:0; position:relative; z-index:3;
  }
  .card-ok {
    background: var(--card-pip, #f5a623);
    color:#111; border:none; border-radius:20px;
    padding: 6px 28px; font-size:.8rem; font-weight:900;
    cursor:pointer; font-family:'Fredoka One'; letter-spacing:.06em;
    box-shadow: 0 3px 0 color-mix(in srgb, var(--card-pip,#f5a623) 60%, #000), 0 4px 12px rgba(0,0,0,.4);
    transition: transform .1s, box-shadow .1s;
    position:relative; top:0;
  }
  .card-ok:hover  { transform:translateY(-2px); box-shadow: 0 5px 0 color-mix(in srgb, var(--card-pip,#f5a623) 60%, #000), 0 8px 16px rgba(0,0,0,.5); }
  .card-ok:active { transform:translateY(2px); box-shadow: 0 1px 0 color-mix(in srgb, var(--card-pip,#f5a623) 60%, #000), 0 2px 6px rgba(0,0,0,.4); top:2px; }
  #game-card-inner.no-dismiss{cursor:default;}
  #game-card-inner.no-dismiss .card-footer{display:none;}

  /* ── Bottom pip (upside-down mirror of top) ── */
  .card-bottom-pip {
    padding: 4px 10px 8px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-shrink: 0;
    position:relative; z-index:3;
  }
  /* border accent along card edge */
  .card-face::after {
    content:'';
    position:absolute; inset:0;
    border-radius:14px;
    border: 1.5px solid rgba(255,255,255,.07);
    pointer-events:none; z-index:4;
  }
  .blast-wall{position:absolute;z-index:80;background:rgba(255,120,0,0.18);border:2px dashed #ff7800;cursor:url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32'><text y='26' font-size='26'>💥</text></svg>") 16 16, crosshair;transition:background .15s;border-radius:12px;box-shadow:0 0 0 1px rgba(255,180,80,.15),0 4px 10px rgba(0,0,0,.18);}
  .blast-wall:hover{background:rgba(255,120,0,0.45);}
  .blast-wall.W,.blast-wall.E{width:24px;height:35%;top:32.5%;transform:none;}
  .blast-wall.N,.blast-wall.S{width:35%;height:24px;left:32.5%;transform:none;}
  .blast-wall.N{top:-12px;}
  .blast-wall.S{bottom:-12px;}
  .blast-wall.W{left:-12px;}
  .blast-wall.E{right:-12px;}

  /* Sticky splat overlay */
  /* ── STICKY GOO — Balatro-style foil seal on the tile ───────────────── */

  .cell.room.sticky-active {
    border-color: #5b21b6 !important;
    box-shadow: 0 0 10px rgba(91,33,182,.55), inset 0 0 6px rgba(91,33,182,.25);
  }

  /* Static settled goo texture — NO animation, always present while stuck */
  .cell.room.sticky-active::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 7px;
    pointer-events: none;
    z-index: 6;
    background:
      repeating-linear-gradient(118deg,
        transparent 0px, rgba(167,139,250,.05) 1px,
        transparent 2px, transparent 8px),
      radial-gradient(ellipse 75% 55% at 38% 32%, rgba(167,139,250,.14) 0%, transparent 65%),
      linear-gradient(160deg, rgba(91,33,182,.48) 0%, rgba(55,15,120,.55) 50%, rgba(30,8,80,.52) 100%);
  }

  /* Slow shimmer sweep */
  .cell.room.sticky-active::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 7px;
    pointer-events: none;
    z-index: 7;
    background: linear-gradient(105deg,
      transparent 35%, rgba(196,167,255,.05) 48%,
      rgba(221,205,255,.09) 52%, transparent 65%);
    background-size: 200% 100%;
    animation: gooShimmer 6s 0s ease-in-out infinite;
  }

  /* One-shot splat flood — class added/removed by JS at the moment of getting stuck */
  .cell.room.sticky-splat-anim::before {
    animation: gooFlood 0.75s cubic-bezier(.25,.46,.45,.94) forwards !important;
  }

  @keyframes gooFlood {
    0%   { inset:30% 40% 60% 40%; border-radius:50%; opacity:0;
           background:radial-gradient(circle, rgba(167,139,250,.7) 0%, rgba(91,33,182,.85) 100%); }
    30%  { inset:15% 20% 40% 20%; border-radius:40% 40% 55% 55%/30% 30% 45% 45%; opacity:1;
           background:radial-gradient(circle, rgba(139,92,246,.45) 0%, rgba(76,29,149,.72) 100%); }
    65%  { inset:0% 0% 0% 0%; border-radius:18% 12% 10% 15%/12% 10% 8% 14%; opacity:1; }
    100% { inset:0; border-radius:7px; opacity:1; }
  }

  @keyframes gooShimmer {
    0%   { background-position:210% 0; opacity:1; }
    25%  { background-position:-10% 0; opacity:1; }
    35%  { background-position:-10% 0; opacity:0; }
    100% { background-position:-10% 0; opacity:0; }
  }

  /* ── CREAKY CRACKS ───────────────────────────────────────────────────── */
  .cell.room.creaky-active {
    outline: 1px solid rgba(0,0,0,.25);
  }

  .creaky-crack-svg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 2;
    overflow: visible;
  }

  /* Already-cracked state — instant full reveal, no animation */
  .creaky-crack-svg.already-cracked .crack-main,
  .creaky-crack-svg.already-cracked .crack-branch,
  .creaky-crack-svg.already-cracked .crack-highlight {
    stroke-dashoffset: 0;
    animation: none;
  }
  .creaky-crack-svg.already-cracked .crack-highlight {
    opacity: 0.12;
  }

  /* Main crack — draws in on first reveal */
  .creaky-crack-svg .crack-main {
    stroke: #1a0a00;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    opacity: 0.55;
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
    animation: crackDrawIn 1.4s 0.1s cubic-bezier(.4,0,.2,1) forwards;
  }
  .creaky-crack-svg .crack-branch {
    stroke: #1a0a00;
    stroke-width: 1.3;
    stroke-linecap: round;
    fill: none;
    opacity: 0.35;
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
    animation: crackDrawIn 0.8s 1.0s cubic-bezier(.4,0,.2,1) forwards;
  }
  .creaky-crack-svg .crack-highlight {
    stroke: #92400e;
    stroke-width: 0.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    opacity: 0;
    stroke-dasharray: 130;
    stroke-dashoffset: 130;
    animation: crackDrawIn 1.4s 0.3s cubic-bezier(.4,0,.2,1) forwards,
               crackHighlightFade 1.2s 1.6s ease forwards;
  }

  /* Impact lines — hidden by default, shown during pulse */
  .creaky-crack-svg .crack-impact {
    opacity: 0;
    stroke: #fff;
    stroke-width: 2;
    stroke-linecap: round;
    fill: none;
  }

  @keyframes crackDrawIn {
    to { stroke-dashoffset: 0; }
  }
  @keyframes crackHighlightFade {
    0%   { opacity: 0.3; }
    100% { opacity: 0.12; }
  }

  /* Re-trigger: comic impact flash */
  .cell.room.creaky-crack-anim {
    animation: crackyCellShake 1.5s ease-out forwards !important;
  }
  .cell.room.creaky-crack-anim .creaky-crack-svg .crack-impact {
    animation: impactFlash 1.5s ease-out forwards !important;
  }
  .cell.room.creaky-crack-anim .creaky-crack-svg .crack-main {
    animation: crackPulse 1.5s ease-out forwards !important;
  }
  .cell.room.creaky-crack-anim .creaky-crack-svg .crack-branch {
    animation: crackPulseBranch 1.5s 0.06s ease-out forwards !important;
  }
  .cell.room.creaky-crack-anim .creaky-crack-svg .crack-highlight {
    animation: crackHighlightPulse 1.5s ease-out forwards !important;
  }

  @keyframes crackyCellShake {
    0%   { transform: scale(1)    translate(0,0)      rotate(0deg); box-shadow: none; }
    5%   { transform: scale(1.08) translate(-3px,-3px) rotate(-1deg); box-shadow: 0 0 24px 6px rgba(255,200,50,.8), 0 0 60px 12px rgba(255,100,0,.5); }
    10%  { transform: scale(1.1)  translate(3px,-2px)  rotate(1deg);  box-shadow: 0 0 32px 8px rgba(255,240,80,.9), 0 0 80px 20px rgba(255,120,0,.6); }
    18%  { transform: scale(1.07) translate(-2px,2px)  rotate(-0.5deg); box-shadow: 0 0 20px 5px rgba(255,180,60,.7); }
    26%  { transform: scale(1.04) translate(2px,-1px)  rotate(0.5deg); box-shadow: 0 0 14px 3px rgba(255,160,40,.5); }
    40%  { transform: scale(1.02) translate(-1px,1px)  rotate(0deg);  box-shadow: 0 0 8px 2px rgba(255,140,20,.3); }
    60%  { transform: scale(1.01) translate(0,0)       rotate(0deg);  box-shadow: 0 0 4px 1px rgba(255,120,0,.15); }
    100% { transform: scale(1)    translate(0,0)       rotate(0deg);  box-shadow: none; }
  }

  @keyframes impactFlash {
