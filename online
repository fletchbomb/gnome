/* === SCREEN SYSTEM v142 === */
.game-screen{
  display:none;
  position:fixed;
  inset:0;
  z-index:1200;
  overflow:hidden;
  padding:24px;
  isolation:isolate;
}
.game-screen.show{display:block;}
.game-screen .screen-backdrop{
  position:absolute;
  inset:0;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
  z-index:0;
}
.game-screen .screen-ui,
.game-screen .weaver-shell,
.game-screen .weaver-vendor{
  position:relative;
  z-index:1;
}

.game-screen.screen-setup .screen-backdrop{
  background-image:url("https://raw.githubusercontent.com/fletchbomb/gnome/main/files/gnome-start.png");
}
.game-screen.screen-victory .screen-backdrop{
  background:radial-gradient(circle at 50% 24%, rgba(76,255,158,.22), transparent 32%), linear-gradient(180deg, rgba(7,22,18,.94), rgba(8,18,35,.98));
}
.game-screen.screen-setup .screen-backdrop::after{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(180deg, rgba(6,10,20,.34) 0%, rgba(6,10,20,.42) 32%, rgba(6,10,20,.58) 100%);
}
.game-screen.screen-setup{
  padding:18px 24px 24px;
  justify-content:flex-start;
  overflow:auto;
}
.game-screen.screen-setup .screen-setup-ui{
  position:relative;
  width:min(1100px, calc(100vw - 48px));
  min-height:100%;
  margin:0 auto;
  display:flex;
  flex-direction:column;
  align-items:center;
}
.game-screen.screen-setup .setup-logo{
  display:block;
  width:min(520px, 72vw);
  max-width:520px;
  margin:6px auto 0;
  filter:drop-shadow(0 12px 28px rgba(0,0,0,.48));
}
.game-screen.screen-setup .setup-start-wrap{
  margin-top:8px;
  display:flex;
  justify-content:center;
}
.game-screen.screen-setup .setup-roster{
  position:relative !important;
  left:auto !important;
  right:auto !important;
  bottom:auto !important;
  top:auto !important;
  transform:none !important;
  width:min(760px, calc(100vw - 48px));
  display:grid;
  grid-template-columns:repeat(4, minmax(160px, 174px));
  justify-content:center;
  gap:11px;
  align-items:end;
  margin:24px auto 0;
  padding-bottom:8px;
  z-index:3;
}

.game-screen.screen-end{
